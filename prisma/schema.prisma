generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  passwordHash   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  incomeStreams   IncomeStream[]
  virtualAccount VirtualAccount?
  transactions   Transaction[]
  proposals      Proposal[]
  aiActions      AIAction[]
}

model IncomeStream {
  id           String        @id @default(cuid())
  userId       String
  name         String
  type         String
  amount       Float
  frequency    String
  currency     String        @default("NGN")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model VirtualAccount {
  id           String        @id @default(cuid())
  userId       String        @unique
  accountNumber String       @unique
  bankName     String
  balance      Float         @default(0)
  currency     String        @default("NGN")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id               String          @id @default(cuid())
  userId           String
  incomeStreamId   String?
  virtualAccountId String?
  type             TransactionType
  amount           Float
  currency         String          @default("NGN")
  description      String?
  status           TxStatus        @default(PENDING)
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeStream     IncomeStream?   @relation(fields: [incomeStreamId], references: [id])
  virtualAccount   VirtualAccount? @relation(fields: [virtualAccountId], references: [id])
}

model Proposal {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String
  amount      Float
  currency    String         @default("NGN")
  status      ProposalStatus @default(DRAFT)
  aiGenerated Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiActions   AIAction[]
}

model AIAction {
  id         String       @id @default(cuid())
  userId     String
  proposalId String?
  type       AIActionType
  prompt     String
  result     Json?
  status     AIStatus     @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposal   Proposal?    @relation(fields: [proposalId], references: [id])
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum AIActionType {
  GENERATE_PROPOSAL
  ANALYZE_INCOME
  SUGGEST_SAVINGS
  FORECAST
  SUMMARIZE
}

enum AIStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
